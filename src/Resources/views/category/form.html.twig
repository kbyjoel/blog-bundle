{% extends '@AropixelAdmin/Form/base.html.twig' %}

{% block meta_title %}{% trans %}categories.form.meta.title{% endtrans %}{% endblock %}
{% block header_title %}{% trans %}categories.form.header.title{% endtrans %}{% endblock %}

{% block header_breadcrumb %}
    <ul class="breadcrumb breadcrumb-caret position-right">
        <li class="breadcrumb-item"><a href="{{ url('_admin') }}">{% trans %}text.dashboard{% endtrans %}</a></li>
        <li class="breadcrumb-item">{% trans %}breadcrumb.blog{% endtrans %}</li>
        <li class="breadcrumb-item"><a href="{{ url('aropixel_blog_category_index') }}">{% trans %}breadcrumb.categories{% endtrans %}</a></li>
        {% if category and category.id %}
            <li class="breadcrumb-item">{% trans %}breadcrumb.form.edit{% endtrans %}</li>
        {% else %}
            <li class="breadcrumb-item active">{% trans %}breadcrumb.form.add{% endtrans %}</li>
        {% endif %}
    </ul>
{% endblock %}

{% block tabbable %}
    <li class="nav-item"><a href="#panel-tab1" data-bs-toggle="pill" class="nav-link active"><span> {% trans %}categories.form.pills.content{% endtrans %}</span></a></li>
{% endblock %}


{% block mainPanel %}

    <div class="tab-pane active" id="panel-tab1">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.name) }}

            </div>

        </div>

    </div>

{% endblock %}
