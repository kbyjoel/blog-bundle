{% extends '@AropixelAdmin/Form/base.html.twig' %}

{% block meta_title %}{% trans %}form.meta.title{% endtrans %}{% endblock %}
{% block header_title %}{% trans %}form.header.title{% endtrans %}{% endblock %}

{% block header_breadcrumb %}
    <ul class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ url('_admin') }}">{% trans %}text.dashboard{% endtrans %}</a></li>
        <li class="breadcrumb-item">{% trans %}breadcrumb.blog{% endtrans %}</li>
        <li class="breadcrumb-item"><a href="{{ url('aropixel_blog_post_index') }}">{% trans %}breadcrumb.list{% endtrans %}</a></li>
        {% if post.id %}
            <li class="breadcrumb-item">{% trans %}breadcrumb.form.edit{% endtrans %}</li>
            <li class="breadcrumb-item active">{{ post.title }}</li>
        {% else %}
            <li class="breadcrumb-item active">{% trans %}breadcrumb.form.add{% endtrans %}</li>
        {% endif %}
    </ul>
{% endblock %}


{% block tabbable %}
    <li class="nav-item"><a href="#panel-tab1" data-bs-toggle="pill" class="nav-link active"><span> {% trans %}form.pills.content{% endtrans %}</span></a></li>
    <li class="nav-item"><a href="#panel-tab2" data-bs-toggle="pill" class="nav-link"><span> {% trans %}form.pills.image{% endtrans %}</span></a></li>
    <li class="nav-item"><a href="#panel-tab3" data-bs-toggle="pill" class="nav-link"><span> {% trans %}form.pills.seo{% endtrans %}</span></a></li>
{% endblock %}


{% block mainPanel %}

    <div class="tab-pane active" id="panel-tab1">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.title) }}

                {% if form.category is defined %}
                    {{ form_row(form.category) }}
                {% endif %}

                {% if form.categories is defined %}
                    {{ form_row(form.categories) }}
                {% endif %}

                {{ form_row(form.excerpt) }}

                {{ form_row(form.description) }}

            </div>

        </div>

    </div>

    <div class="tab-pane" id="panel-tab2">


        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.image) }}

            </div>

        </div>

    </div>

    <div class="tab-pane" id="panel-tab3">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.metaTitle) }}

                {{ form_row(form.metaDescription) }}

                {{ form_row(form.metaKeywords) }}

            </div>

        </div>

    </div>

{% endblock %}

